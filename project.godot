; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Vincent"
config/description="Digital art and image editing software project."
config/version="0.2.0_prealpha"
config/tags=PackedStringArray("application")
run/main_scene="uid://qubiww5n0s3j"
config/use_custom_user_dir=true
config/custom_user_dir_name="vincent"
config/features=PackedStringArray("4.7", "GL Compatibility")
run/max_fps=120
run/low_processor_mode=true
boot_splash/show_image=false
config/icon="uid://tsr3qvb2uqet"
boot_splash/minimum_display_time=500

[audio]

driver/driver="Dummy"

[autoload]

Enums="*res://scripts/enums.gd"
Utils="*res://scripts/utils.gd"
ConfigManager="*uid://6wqg7flfqe3j"
StateManager="*res://scripts/state_manager.gd"
CanvasManager="*uid://bidmpfe1sxwvh"
HistoryManager="*uid://7d25tnoi2427"
PopupManager="*res://scripts/popup_manager.gd"
ToolManager="*uid://ceqygovtbubm0"
PanelManager="*uid://bcbehstlwjuwb"
PluginManager="*uid://bb6a1l22kac3g"
LocaleCoverageTester="*uid://c4w2m1d3335na"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/sharp_corners=true
window/energy_saving/keep_screen_on=false
window/subwindows/embed_subwindows=false
window/vsync/vsync_mode=0

[dotnet]

project/assembly_name="Vincent"

[gui]

common/snap_controls_to_pixels=false
theme/custom="uid://n486m4af3wkh"
theme/custom_font="uid://cbfq16it13oy6"

[importer_defaults]

csv_translation={
&"compress": 0
}

[internationalization]

locale/translations=PackedStringArray("res://locale/de_DE.de_DE.translation", "res://locale/en_US.en_US.translation")
locale/fallback="en_US"
locale/locale_filter_mode=0

[rendering]

rendering_device/fallback_to_opengl3=false
renderer/rendering_method="mobile"
textures/lossless_compression/force_png=true
environment/defaults/default_clear_color=Color(0.2, 0.2, 0.2, 1)
